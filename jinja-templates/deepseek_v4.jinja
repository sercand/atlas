{%- set bos_token = "<｜begin▁of▁sentence｜>" -%}
{%- set eos_token = "<｜end▁of▁sentence｜>" -%}
{%- set thinking_start_token = "" -%}
{%- set thinking_end_token = "" -%}
{%- set user_token = "<｜User｜>" -%}
{%- set assistant_token = "<｜Assistant｜>" -%}

{%- if not messages %}
    {{- raise_exception('No messages provided.') }}
{%- endif %}

{%- macro render_content(content) %}
    {%- if content is string %}
        {{- content }}
    {%- elif content is iterable and content is not mapping %}
        {%- for item in content %}
            {%- if 'text' in item %}
                {{- item.text }}
            {%- elif 'image' in item or 'image_url' in item %}
                {{- '[Image]' }}
            {%- else %}
                {{- raise_exception('Unexpected item type in content.') }}
            {%- endif %}
        {%- endfor %}
    {%- elif content is none or content is undefined %}
        {{- '' }}
    {%- else %}
        {{- raise_exception('Unexpected content type.') }}
    {%- endif %}
{%- endmacro %}

{%- set first_message = true -%}
{%- for message in messages %}
    {%- set content = render_content(message.content) -%}
    {%- if message.role == "system" %}
        {%- if first_message %}
            {{- bos_token }}
        {%- endif %}
        {{- content }}
    {%- elif message.role == "user" %}
        {%- if first_message %}
            {{- bos_token }}
        {%- endif %}
        {{- user_token + content + assistant_token }}
    {%- elif message.role == "assistant" %}
        {%- set reasoning_content = '' -%}
        {%- if message.reasoning_content is string %}
            {%- set reasoning_content = message.reasoning_content -%}
        {%- endif %}
        {%- set reasoning_content = reasoning_content | trim -%}
        {%- if reasoning_content %}
            {{- thinking_start_token + reasoning_content + thinking_end_token }}
        {%- endif %}
        {{- content + eos_token }}
    {%- else %}
        {{- raise_exception('Unexpected message role.') }}
    {%- endif %}
    {%- set first_message = false -%}
{%- endfor %}

{%- if add_generation_prompt %}
    {%- if enable_thinking is defined and enable_thinking == false %}
        {{- thinking_end_token }}
    {%- else %}
        {{- thinking_start_token }}
    {%- endif %}
{%- endif %}
